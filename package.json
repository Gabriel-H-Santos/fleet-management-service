{
  "name": "fleet-management-service",
  "version": "1.0.0",
  "description": "Vehicle usage control API for company fleet management",
  "main": "src/index.ts",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "start": "tsx ./src/index.ts",
    "dev": "tsx watch ./src/index.ts",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix --cache --cache-location .eslintcache",
    "format": "prettier -w .",
    "infra:up": "docker compose up -d",
    "infra:stop": "docker compose stop",
    "infra:down": "docker compose down --remove-orphans --volumes",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:verbose": "cross-env NODE_ENV=test jest --verbose"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-plugin-prettier": "^5.2.2",
    "fishery": "^2.3.1",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.20.0"
  }
}
